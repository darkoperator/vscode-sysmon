{
	"name": "sysmon",
	"displayName": "Sysmon",
	"description": "Microsoft Sysinternals Sysmon Configuration file authoring extension.",
	"version": "1.9.0",
	"engines": {
		"vscode": "^1.70.0"
	},
	"categories": [
		"Other",
		"Programming Languages",
		"Snippets"
	],
	"activationEvents": [
		"onLanguage:smc"
	],
	"main": "./out/extension.js",
	"contributes": {
		"snippets": [
			{
				"language": "smc",
				"path": "./snippets/smc.json"
			}
		],
		"languages": [
			{
				"id": "smc",
				"aliases": [
					"Sysmon",
					"smc"
				],
				"extensions": [
					".smc"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "smc",
				"scopeName": "source.sysmon",
				"path": "./syntaxes/smc.tmLanguage.json"
			}
		],
		"configuration": {
			"title": "Sysmon",
			"properties": {
				"sysmon.platform": {
					"type": "string",
					"default": "windows",
					"enum": [
						"windows"
					],
					"description": "Sysmon platform used for completions and diagnostics."
				},
				"sysmon.schemaVersion": {
					"type": "string",
					"default": "4.91",
					"enum": [
						"4.91",
						"4.90"
					],
					"description": "Sysmon schema version used for completions and diagnostics."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/glob": "^7.1.1",
		"@types/mocha": "^5.2.6",
		"@types/node": "^10.12.21",
		"@types/vscode": "^1.39.0",
		"@vscode/test-electron": "^2.5.2",
		"glob": "^7.1.4",
		"mocha": "^11.3.0",
		"tslint": "^5.8.0",
		"typescript": "^3.3.1"
	},
	"overrides": {
		"serialize-javascript": "^7.0.6"
	},
	"license": "SEE LICENSE IN LICENSE.txt",
	"bugs": {
		"url": "https://github.com/darkoperator/vscode-sysmon/issues",
		"email": "carlos_perez@darkoperator.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/darkoperator/vscode-sysmon.git"
	},
	"homepage": "https://github.com/darkoperator/vscode-sysmon/blob/master/README.md",
	"icon": "images/icon.png",
	"galleryBanner": {
		"color": "#ACD1EC",
		"theme": "light"
	},
	"publisher": "DarkOperator",
	"__metadata": {
		"id": "0b631589-0c5b-445d-aeab-c1bda6b98946",
		"publisherDisplayName": "DarkOperator",
		"publisherId": "84336c4a-0cf5-4d58-b3c0-072b41cacc30"
	}
}
